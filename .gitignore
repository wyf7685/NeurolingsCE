# =============================================================================
# NeurolingsCE .gitignore
# Blacklist approach: only list what to ignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Build directories
# -----------------------------------------------------------------------------
build/
build-*/
Build/
cmake-build-*/
out/
_build/
publish/
AppDir/

# -----------------------------------------------------------------------------
# CMake generated files
# -----------------------------------------------------------------------------
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
install_manifest.txt
CTestTestfile.cmake
compile_commands.json
_deps/
CMakeUserPresets.json
*_autogen/

# -----------------------------------------------------------------------------
# Make build artifacts (generated at project root by Makefile)
# -----------------------------------------------------------------------------
DefaultMascot.cc
licenses_generated.hpp
qrc_*.cc
*.qm
shijima-qt
shijima-qt.exe
shijima-qt.a
*.AppImage
!include/shijima-qt/
!include/shijima-qt/ui/
!include/shijima-qt/ui/**

# -----------------------------------------------------------------------------
# C/C++ object files & dependencies
# -----------------------------------------------------------------------------
*.o
*.obj
*.d
*.lo
*.slo
*.gch
*.pch

# Libraries (compiled)
*.a
*.lib
*.la
*.lai
*.so
*.so.*
*.dylib
*.dll

# Executables
*.exe
*.out

# Linker & debug
*.ilk
*.pdb
*.idb
*.dwo
*.exp

# -----------------------------------------------------------------------------
# Ninja
# -----------------------------------------------------------------------------
build.ninja
.ninja_deps
.ninja_log

# -----------------------------------------------------------------------------
# Visual Studio / MSVC
# -----------------------------------------------------------------------------
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.rsuser
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb
*.iobj
*.ipdb
*.tlog

# -----------------------------------------------------------------------------
# Qt Creator
# -----------------------------------------------------------------------------
*.pro.user
*.pro.user.*
*.qbs.user
*.qbs.user.*
*.autosave
CMakeLists.txt.user*
.qmake.cache
.qmake.stash
.qt/
.qtc/
.qtc_clangd/

# -----------------------------------------------------------------------------
# JetBrains CLion
# -----------------------------------------------------------------------------
.idea/

# -----------------------------------------------------------------------------
# VS Code (keep settings if shared; ignore the rest)
# -----------------------------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
__MACOSX/
._*
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes

# -----------------------------------------------------------------------------
# Windows
# -----------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Linux
# -----------------------------------------------------------------------------
*~
.directory
.Trash-*
.nfs*
nohup.out

# -----------------------------------------------------------------------------
# Temporary & editor files
# -----------------------------------------------------------------------------
*.tmp
*.log
*.bak
*.swp
*.swo
*.orig
\#*\#
.#*

# -----------------------------------------------------------------------------
# Package managers
# -----------------------------------------------------------------------------
vcpkg_installed/
.cache/

# -----------------------------------------------------------------------------
# Submodule build artifacts (generated inside submodule dirs by Make)
# -----------------------------------------------------------------------------
libshijima/build/
libshimejifinder/build/
/nul
/src/platform/Platform/AGENTS.md
/src/platform/Platform/Linux/gnome_script.c
/src/platform/Platform/Linux/kwin_script.c
/build_test.bat
/build_output.txt
